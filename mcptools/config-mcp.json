{
  "mcpServers": {
    "wikipedia": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-trunc-proxy",
        "--max-bytes",
        "20000",
        "--preview-max-chars",
        "3000",
        "--head-lines",
        "40",
        "--tail-lines",
        "20",
        "--store",
        "file:/tmp/mcp-trunc-proxy/",
        "--",
        "npx",
        "-y",
        "wikipedia-mcp",
        "--language",
        "fr"
      ]
    },
    "stackoverflow": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-trunc-proxy",
        "--max-bytes",
        "20000",
        "--preview-max-chars",
        "3000",
        "--store",
        "file:/tmp/mcp-trunc-proxy/",
        "--",
        "uvx",
        "stackoverflow-mcp"
      ]
    },
    "search": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-trunc-proxy",
        "--max-bytes",
        "20000",
        "--preview-max-chars",
        "3000",
        "--store",
        "file:/tmp/mcp-trunc-proxy/",
        "--",
        "npx",
        "-y",
        "mcp-searxng"
      ],
      "env": {
        "SEARXNG_URL": "http://localhost:8888"
      }
    },
    "python": {
      "command": "uvx",
      "args": [
        "--with",
        "sympy",
        "--with",
        "numpy",
        "--with",
        "scipy",
        "--with",
        "matplotlib",
        "--with",
        "pandas",
        "mcp-python-interpreter",
        "--dir",
        "$HOME/gitlab/mcp-configs",
        "--python-path",
        "$HOME/gitlab/mcp-configs/.venv/bin/python"
      ],
      "env": {
        "MCP_ALLOW_SYSTEM_ACCESS": "1"
      }
    }
  }
}
